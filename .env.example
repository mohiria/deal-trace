# Copy to .env and fill in deployment-specific values.

# External MySQL connection. The database name is fixed by the application as `dealtrace`.
DB_HOST=mysql-host.example.com
DB_PORT=3306
DB_USER=dealtrace
DB_PASSWORD=change-me

# JWT secret must be at least 32 bytes for HS256.
DEALTRACE_JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-bytes

# Initial Admin bootstrap. If any ADMIN already exists in DB, backend will not overwrite it.
DEALTRACE_ADMIN_EMAIL=admin@dealtrace.local
DEALTRACE_ADMIN_PASSWORD=change-me

# Host ports.
BACKEND_PORT=8080
FRONTEND_PORT=8081
