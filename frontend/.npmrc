# pnpm 在每次 `pnpm <script>` 前会跑一次 deps 校验（runDepsStatusCheck）。
# 本项目 esbuild / vue-demi / msw 的 build script 被标记为 ignored（功能上均正常：
# esbuild 平台二进制在 .pnpm 内、vue-demi 已 switch 出 v3、msw 仅 node 端无需 worker），
# 但该校验会因 ERR_PNPM_IGNORED_BUILDS 直接以 exit 1 中断脚本运行。
# 关闭该前置校验，让 test:unit / build 等脚本可正常执行。
verify-deps-before-run=false
